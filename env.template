# =============================================
# Polymarket AI Prediction Bot 환경변수
# =============================================

# ┌─────────────────────────────────────────────┐
# │  PAPER 트레이딩 — 이것만 있으면 됨 (2개)     │
# └─────────────────────────────────────────────┘

# Gemini API (Google AI Studio에서 발급)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ┌─────────────────────────────────────────────┐
# │  PAPER 설정 (선택, 기본값 있음)               │
# └─────────────────────────────────────────────┘

LIVE_TRADING_ENABLED=false
INITIAL_BANKROLL=1000.0
DAILY_AI_COST_LIMIT=2.0
LOG_LEVEL=INFO

# Telegram 알림 (선택 — 없어도 작동)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ┌─────────────────────────────────────────────┐
# │  LIVE 트레이딩 전용 — Paper에선 무시됨        │
# └─────────────────────────────────────────────┘

# Polymarket CLOB API (https://docs.polymarket.com)
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# Polygon 지갑
PK=
POLYMARKET_PROXY_ADDRESS=

# Polygon RPC
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# ┌─────────────────────────────────────────────┐
# │  고급 설정 (Ensemble, 선택)                   │
# └─────────────────────────────────────────────┘

ENSEMBLE_ENABLED=false
ENSEMBLE_TRADER_MODEL=gemini-3.1-pro-preview
